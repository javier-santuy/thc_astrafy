
connection: "connection_name"

include: "/views/**/*.view"

datagroup: ecommerce_datagroup {
  sql_trigger: SELECT MAX(id) FROM `your_project.your_dataset.stg_orders_raw__sales_recrutement` ;;
  max_cache_age: "24 hours"
