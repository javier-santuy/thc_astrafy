view: order_segmentation {
  derived_table: {
    datagroup_trigger: ecommerce_datagroup
    
    cluster_keys: ["customer_id"]
    partition_keys: ["order_date"]

    sql:
      WITH orders_with_history AS (
          SELECT 
              order_id,
              customer_id,
              date_date AS order_date,
              COUNT(*) OVER (
                  PARTITION BY customer_id 
                  ORDER BY UNIX_DATE(date_date) 
                  RANGE BETWEEN 365 PRECEDING AND 1 PRECEDING
              ) AS orders_in_last_12_months
          FROM ${stg_orders_raw__sales_recrutement.SQL_TABLE_NAME}
          GROUP BY order_id, customer_id, date_date
      )
      SELECT * FROM orders_with_history
      WHERE EXTRACT(YEAR FROM order_date) = 2023
    ;;
  }

  # --- DIMENSIONS ---

  dimension: order_id {
    primary_key: yes
    type: string
    sql: ${TABLE}.order_id ;;
  }

  dimension: customer_id {
    type: string
    sql: ${TABLE}.customer_id ;;
  }

  dimension_group: order_date {
    type: time
    timeframes: [raw, date, month, year]
    convert_tz: no
    datatype: date
    sql: ${TABLE}.order_date ;;
  }

  dimension: orders_in_last_12_months {
    type: number
    description: "Count of orders placed by the customer in the 12 months prior to this order date"
    sql: ${TABLE}.orders_in_last_12_months ;;
  }


  dimension: order_segment {
    type: string
    description: "Customer segment based on historical order frequency"
    sql:
      CASE 
        WHEN ${orders_in_last_12_months} = 0 THEN 'New'
        WHEN ${orders_in_last_12_months} BETWEEN 1 AND 3 THEN 'Returning'
        WHEN ${orders_in_last_12_months} >= 4 THEN 'VIP'
        ELSE 'Unknown'
      END ;;
  }

  # --- MEASURES ---

  measure: count {
    type: count
    drill_fields: [order_id, customer_id, order_segment]
  }
  
  measure: total_customers {
    type: count_distinct
    sql: ${customer_id} ;;
  }
}